{
  "name": "hermes-workflows",
  "version": "0.7.8",
  "private": true,
  "description": "Visual workflow orchestration for Hermes — compiles a graph spec onto native Kanban, Cron, and Profiles.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint -c oxlint.json",
    "lint:fix": "oxlint -c oxlint.json --fix",
    "fmt": "oxfmt --write '**/*.{ts,js,json}' '!dashboard/dist/**' --no-error-on-unmatched-pattern",
    "fmt:check": "oxfmt --check '**/*.{ts,js,json}' '!dashboard/dist/**' --no-error-on-unmatched-pattern",
    "test": "bun test packages/core",
    "test:py": "python3 -m pytest",
    "dashboard:typecheck": "bun run --filter='@hermes-workflows/dashboard' typecheck",
    "dashboard:test": "bun run --filter='@hermes-workflows/dashboard' test",
    "dashboard:build": "bun run --filter='@hermes-workflows/dashboard' build",
    "dashboard:bump": "bun run apps/dashboard/scripts/bump-build.ts",
    "dashboard:rebuild": "bun run dashboard:bump && bun run dashboard:build",
    "dashboard:check": "git diff --exit-code -- dashboard/dist",
    "validate": "bun run typecheck && bun run lint && bun run test && bun run test:py && bun run dashboard:typecheck && bun run dashboard:test && bun run dashboard:build && bun run dashboard:check"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "typescript": "^5.5.0"
  }
}
